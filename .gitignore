# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
*.tsbuildinfo

# Compiled artifacts emitted next to TypeScript sources.
# Bare *.d.ts is deliberately not ignored: authored ambient declarations
# may legitimately live under src/.
packages/*/src/**/*.js
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts.map

# Environment variables
.env
.env.local
.env.*.local

# Testing
coverage/
.nyc_output

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
tmp/
temp/
*.tmp
