# UISchema Environment Variables
# Copy this file to .env and fill in your values

# ── Groq (recommended — fastest, generous free tier) ──────────────────────────
# Get a free API key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# ── OpenAI ─────────────────────────────────────────────────────────────────────
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenRouter (access all models via one key) ─────────────────────────────────
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# ── Model override ─────────────────────────────────────────────────────────────
# Override the default model used by the CLI generate command
# AI_SDK_MODEL=llama-3.3-70b-versatile

# ── Optional ───────────────────────────────────────────────────────────────────
# NODE_ENV=development
# DEBUG=uischema:*

# Priority order for API key auto-detection:
#   GROQ_API_KEY > OPENAI_API_KEY > ANTHROPIC_API_KEY
#
# Groq is recommended for local development:
#   - Llama 3.3 70B runs at 800+ tokens/second
#   - Free tier: 14,400 requests/day
#   - Zero latency models: llama-3.1-8b-instant
#
# Never commit your .env file to version control (it's in .gitignore)
